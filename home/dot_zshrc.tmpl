# shellcheck shell=bash disable=SC1090,SC1091,SC2034

# Keep zsh boring: history, completion, local env, and modern tool hooks.

setopt HIST_IGNORE_ALL_DUPS
setopt SHARE_HISTORY
setopt EXTENDED_HISTORY
setopt INC_APPEND_HISTORY
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS

bindkey -e
WORDCHARS=${WORDCHARS//[\/]}

HISTFILE="${HOME}/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000

autoload -Uz compinit
compinit

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

PROMPT='%F{cyan}%~%f %# '

load_env_files() {
  local file_path key value current

  for file_path in "$@"; do
    [[ -f "${file_path}" ]] || continue
    while IFS='=' read -r key value; do
      [[ -z "${key}" || "${key}" == \#* ]] && continue
      key="${key#"${key%%[![:space:]]*}"}"
      key="${key%"${key##*[![:space:]]}"}"
      value="${value#"${value%%[![:space:]]*}"}"
      value="${value%"${value##*[![:space:]]}"}"
      value="${value%\"}"
      value="${value#\"}"
      value="${value%\'}"
      value="${value#\'}"
      [[ "${key}" =~ '^[A-Za-z_][A-Za-z0-9_]*$' ]] || continue
      eval "current=\${${key}+x}"
      [[ -n "${current}" ]] && continue
      export "${key}=${value}"
    done <"${file_path}"
  done
}

source_if_exists() {
  local file_path=$1
  [[ -r "${file_path}" ]] && source "${file_path}"
}

load_zsh_plugin() {
  local plugin=$1

  case "$(uname -s)" in
  Darwin)
    source_if_exists "/opt/homebrew/share/${plugin}/${plugin}.zsh"
    source_if_exists "/usr/local/share/${plugin}/${plugin}.zsh"
    ;;
  Linux)
    source_if_exists "/usr/share/zsh/plugins/${plugin}/${plugin}.zsh"
    source_if_exists "/usr/share/${plugin}/${plugin}.zsh"
    ;;
  esac
}

unsetproxy() {
  unset PROXY_HOST PROXY_PORT
  unset NO_PROXY ALL_PROXY HTTP_PROXY HTTPS_PROXY
  unset no_proxy all_proxy http_proxy https_proxy
}

setproxy() {
  local url

  unsetproxy
  [[ ${USE_PROXY:-true} == "true" ]] || return

  url=${PROXY_URL:-http://127.0.0.1:8899}
  PROXY_HOST=$(echo "${url}" | awk -F'://|:' '{print $2}')
  PROXY_PORT=$(echo "${url}" | awk -F'://|:' '{print $3}')
  export PROXY_HOST PROXY_PORT
  export NO_PROXY="^\\(localhost\\|10\\..*\\|192\\.168\\..*\\)"
  export ALL_PROXY="${url}"
  export HTTP_PROXY="${url}"
  export HTTPS_PROXY="${url}"
}

proxyinfo() {
  echo "PROXY_HOST = ${PROXY_HOST}"
  echo "PROXY_PORT = ${PROXY_PORT}"
  echo "NO_PROXY = ${NO_PROXY}"
  echo "ALL_PROXY = ${ALL_PROXY}"
  echo "HTTP_PROXY = ${HTTP_PROXY}"
  echo "HTTPS_PROXY = ${HTTPS_PROXY}"
}

load_env_files "${HOME}/.config/dotfiles/env" "${HOME}/.dotfiles.env" "${HOME}/.env_private"
setproxy

if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh --quiet)"
fi

if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

if [[ -t 0 && -t 1 ]] && command -v fzf >/dev/null 2>&1; then
  source_if_exists <(fzf --zsh)
fi

load_zsh_plugin zsh-autosuggestions
load_zsh_plugin zsh-syntax-highlighting

if (( ${+commands[bat]} )); then
  alias cat="bat"
fi

alias pn="pnpm"
alias gf="git pull"
alias myip="curl myip.ipip.net"

export EDITOR="vim"
export LC_MESSAGES="en_US.UTF-8"
export HOMEBREW_NO_AUTO_UPDATE=1

## vim:ft=zsh
