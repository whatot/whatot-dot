# shellcheck shell=bash disable=SC1090,SC1091,SC2034

# Core shell behavior.
setopt HIST_IGNORE_ALL_DUPS
setopt SHARE_HISTORY
setopt EXTENDED_HISTORY
setopt INC_APPEND_HISTORY
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS

bindkey -e
WORDCHARS=${WORDCHARS//[\/]}

HISTFILE="${HOME}/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000

# Base environment.
export EDITOR="vim"
export LC_MESSAGES="en_US.UTF-8"
export HOMEBREW_NO_AUTO_UPDATE=1

# Shared shell state.
DOTFILES_SHELL_OS="$(uname -s)"
DOTFILES_ENV_FILES=("${HOME}/.dotfiles.env" "${HOME}/.env_private")
DOTFILES_ZSH_MODULES=(network tools aliases prompt)

load_env_files() {
  local file_path key value current

  for file_path in "$@"; do
    [[ -f "${file_path}" ]] || continue
    while IFS='=' read -r key value; do
      [[ -z "${key}" || "${key}" == \#* ]] && continue
      key="${key#"${key%%[![:space:]]*}"}"
      key="${key%"${key##*[![:space:]]}"}"
      value="${value#"${value%%[![:space:]]*}"}"
      value="${value%"${value##*[![:space:]]}"}"
      value="${value%\"}"
      value="${value#\"}"
      value="${value%\'}"
      value="${value#\'}"
      [[ "${key}" =~ '^[A-Za-z_][A-Za-z0-9_]*$' ]] || continue
      eval "current=\${${key}+x}"
      [[ -n "${current}" ]] && continue
      export "${key}=${value}"
    done <"${file_path}"
  done
}

source_if_exists() {
  local file_path=$1
  [[ -r "${file_path}" ]] && source "${file_path}"
}

is_command() {
  (( ${+commands[$1]} ))
}

# Module loading.
source_zsh_module() {
  local module_name=$1
  source_if_exists "${HOME}/.zsh/${module_name}.zsh"
}

load_zsh_modules() {
  local module_name

  for module_name in "${DOTFILES_ZSH_MODULES[@]}"; do
    source_zsh_module "${module_name}"
  done
}

# Startup.
initialize_shell() {
  load_env_files "${DOTFILES_ENV_FILES[@]}"
  setproxy
  setup_completion
  setup_tool_hooks
  load_optional_plugins
  setup_aliases
  setup_vcs_info
  setup_prompt
}

load_zsh_modules
initialize_shell

## vim:ft=zsh
