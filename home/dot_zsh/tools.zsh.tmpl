fpath_prepend() {
  [[ -d "$1" ]] || return
  fpath=("$1" "${(@)fpath:#$1}")
}

register_completion() {
  local command_name=$1
  local function_name=$2
  local service=${3:-}

  (( ${+functions[${function_name}]} )) || return
  if [[ -n "${service}" ]]; then
    compdef "${function_name}" "${command_name}=${service}"
  else
    compdef "${function_name}" "${command_name}"
  fi
}

_mise_run_completion() {
  local -a original_words
  local original_current

  (( ${+functions[_mise]} )) || return 1

  original_words=("${words[@]}")
  original_current=$CURRENT

  local -a words=("mise" "run" "${original_words[@]:1}")
  integer CURRENT=$(( original_current + 1 ))

  _mise
}

load_zsh_plugin() {
  local plugin=$1

  case "${DOTFILES_SHELL_OS}" in
  Darwin)
    source_if_exists "/opt/homebrew/share/${plugin}/${plugin}.zsh"
    source_if_exists "/usr/local/share/${plugin}/${plugin}.zsh"
    ;;
  Linux)
    source_if_exists "/usr/share/zsh/plugins/${plugin}/${plugin}.zsh"
    source_if_exists "/usr/share/${plugin}/${plugin}.zsh"
    ;;
  esac
}

setup_completion() {
  local completion_cache_dir

  case "${DOTFILES_SHELL_OS}" in
  Darwin)
    fpath_prepend "/opt/homebrew/share/zsh/site-functions"
    fpath_prepend "/usr/local/share/zsh/site-functions"
    ;;
  Linux)
    fpath_prepend "/usr/local/share/zsh/site-functions"
    fpath_prepend "/usr/share/zsh/site-functions"
    fpath_prepend "/usr/share/zsh/vendor-completions"
    ;;
  esac

  completion_cache_dir="${XDG_CACHE_HOME:-${HOME}/.cache}/zsh"
  if ! mkdir -p "${completion_cache_dir}" 2>/dev/null; then
    completion_cache_dir="${TMPDIR:-/tmp}"
  fi

  zmodload -i zsh/complist
  autoload -Uz add-zsh-hook colors compinit vcs_info
  compinit -d "${completion_cache_dir}/.zcompdump-${ZSH_VERSION}"
  colors

  zstyle ':completion:*' menu select
  zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
  zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
  zstyle ':completion:*' rehash true
}

setup_tool_hooks() {
  if is_command mise; then
    eval "$(mise activate zsh --quiet --shims)"
    if is_command usage; then
      source_if_exists <(mise completion zsh)
    fi
  fi

  if is_command zoxide; then
    eval "$(zoxide init zsh)"
  fi

  if is_command direnv; then
    eval "$(direnv hook zsh)"
  fi

  if [[ -t 0 && -t 1 ]] && is_command fzf; then
    source_if_exists <(fzf --zsh)
  fi

  if is_command pnpm; then
    source_if_exists <(pnpm completion zsh)
  fi
}

load_optional_plugins() {
  load_zsh_plugin zsh-autosuggestions
  load_zsh_plugin zsh-syntax-highlighting
}
