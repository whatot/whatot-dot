PROMPT_LAST_COMMAND_START=
PROMPT_LAST_COMMAND_ACTIVE=0

format_prompt_duration() {
  local total_seconds=$1

  if (( total_seconds >= 3600 )); then
    printf '%dh%dm%ds' \
      $(( total_seconds / 3600 )) \
      $(( (total_seconds % 3600) / 60 )) \
      $(( total_seconds % 60 ))
  elif (( total_seconds >= 60 )); then
    printf '%dm%ds' \
      $(( total_seconds / 60 )) \
      $(( total_seconds % 60 ))
  else
    printf '%ds' "${total_seconds}"
  fi
}

prompt_context() {
  if [[ -n "${SSH_CONNECTION:-}" ]]; then
    printf '%%F{yellow}%%m%%f '
  fi
}

setup_git_prompt() {
  ZSH_GIT_PROMPT_NO_ASYNC=1
  ZSH_GIT_PROMPT_SHOW_STASH=1
  ZSH_GIT_PROMPT_SHOW_UPSTREAM=symbol
  ZSH_GIT_PROMPT_SHOW_TRACKING_COUNTS=1
  ZSH_GIT_PROMPT_SHOW_LOCAL_COUNTS=0
  ZSH_THEME_GIT_PROMPT_PREFIX=' %F{244}|%f '
  ZSH_THEME_GIT_PROMPT_SUFFIX=''
  ZSH_THEME_GIT_PROMPT_SEPARATOR=' %F{244}·%f '
  ZSH_THEME_GIT_PROMPT_BRANCH='%F{magenta}'
  ZSH_THEME_GIT_PROMPT_UPSTREAM_SYMBOL=' %F{yellow}⇅%f'
  ZSH_THEME_GIT_PROMPT_UPSTREAM_NO_TRACKING=''
  ZSH_THEME_GIT_PROMPT_BEHIND='%F{yellow}↓%f'
  ZSH_THEME_GIT_PROMPT_AHEAD='%F{yellow}↑%f'
  ZSH_THEME_GIT_PROMPT_UNMERGED='%F{red}✖%f'
  ZSH_THEME_GIT_PROMPT_STAGED='%F{green}+%f'
  ZSH_THEME_GIT_PROMPT_UNSTAGED='%F{red}*%f'
  ZSH_THEME_GIT_PROMPT_UNTRACKED='%F{yellow}?%f'
  ZSH_THEME_GIT_PROMPT_STASHED='%F{blue}$%f'
  ZSH_THEME_GIT_PROMPT_CLEAN='%F{green}=%f'

  source_if_exists "${HOME}/.zsh/vendor/git-prompt.zsh"
}

prompt_vcs_segment() {
  gitprompt
}

prompt_duration_segment() {
  local total_seconds=$1

  if (( total_seconds < 1 )); then
    return
  fi

  printf ' %%F{244}·%%f %%F{yellow}%s%%f' "$(format_prompt_duration "${total_seconds}")"
}

record_command_start() {
  PROMPT_LAST_COMMAND_START=${SECONDS}
  PROMPT_LAST_COMMAND_ACTIVE=1
}

update_prompt() {
  local vcs_segment=
  local duration_segment=
  local elapsed_seconds

  if [[ ${PROMPT_LAST_COMMAND_ACTIVE:-0} -eq 1 ]]; then
    elapsed_seconds=$(( SECONDS - PROMPT_LAST_COMMAND_START ))
    duration_segment="$(prompt_duration_segment "${elapsed_seconds}")"
    PROMPT_LAST_COMMAND_ACTIVE=0
  fi

  vcs_segment="$(prompt_vcs_segment)"
  PROMPT="$(prompt_context)%F{cyan}%~%f${vcs_segment}${duration_segment}
%(?.%F{green}.%F{red})%#%f "
  RPROMPT='%F{blue}%*%f'
}

setup_prompt() {
  add-zsh-hook preexec record_command_start
  add-zsh-hook precmd update_prompt
  setup_git_prompt
  update_prompt
}
