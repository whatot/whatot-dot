[user]
	email = {{ env "DOTFILES_GIT_EMAIL" }}
	name = {{ env "DOTFILES_GIT_NAME" }}
{{- $gitIncludeRules := env "DOTFILES_GIT_INCLUDE_RULES" }}
{{- if $gitIncludeRules }}
{{- range $rule := splitList "," $gitIncludeRules }}
{{- $parts := splitList ":" $rule }}
{{- if ge (len $parts) 2 }}
{{- $gitDir := trim (index $parts 0) }}
{{- $includePath := trim (index $parts 1) }}
{{- if and $gitDir $includePath }}
[includeIf "gitdir/i:{{ $gitDir }}{{ if not (hasSuffix "/" $gitDir) }}/{{ end }}"]
	path = {{ $includePath }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
[credential]
	helper = cache --timeout 3600
[merge]
	tool = meld
[color]
	ui = auto
	branch = auto
	diff = auto
	interactive = auto
	status = auto
[core]
	autocrlf = input
	editor = vim
	ignorecase = false
[push]
	default = upstream
[alias]
	br = branch
	ci = commit
	co = checkout
	last = log --pretty=oneline -1 HEAD
	glog = log --graph  --abbrev-commit --date=relative --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%Cblue%an%Creset%Cgreen %cr)%Creset '
	st = status

	# Remove the latest commit but keep the working tree changes.
	undo = reset --soft HEAD^
	# Remove the latest commit and discard the working tree changes.
	cancel = reset --hard HEAD^
	# Amend the latest commit without changing its message.
	onemore = commit -a --amend --no-edit
[http]
	postBuffer = 524288000
	lowSpeedLimit = 0
	lowSpeedTime = 999999
[pull]
	ff = only
	rebase = false
[init]
	defaultBranch = main
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
