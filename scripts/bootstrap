#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
# shellcheck source=scripts/lib/platform
source "${ROOT_DIR}/scripts/lib/platform"

kernel_name="$(dotfiles_kernel_name)"

case "${kernel_name}" in
  Darwin)
    "${ROOT_DIR}/bootstrap/macos.sh"
    ;;
  Linux)
    linux_id="$(dotfiles_linux_release_id)"
    case "${linux_id}" in
      arch | manjaro)
        "${ROOT_DIR}/bootstrap/arch.sh"
        ;;
      debian)
        "${ROOT_DIR}/bootstrap/debian.sh"
        ;;
      *)
        echo "unsupported linux distribution: ${linux_id}" >&2
        exit 1
        ;;
    esac
    ;;
  *)
    echo "unsupported os: ${kernel_name}" >&2
    exit 1
    ;;
esac

export PATH="${HOME}/.local/bin:${HOME}/.cargo/bin:/opt/homebrew/bin:/usr/local/bin:${PATH}"
"${ROOT_DIR}/scripts/preflight"
chezmoi init --source "${ROOT_DIR}"
"${ROOT_DIR}/scripts/chezmoi" apply
