#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"

case "$(uname -s)" in
  Darwin)
    "${ROOT_DIR}/bootstrap/macos.sh"
    ;;
  Linux)
    if [[ -r /etc/os-release ]]; then
      # shellcheck disable=SC1091
      . /etc/os-release
    else
      echo "unsupported linux: missing /etc/os-release" >&2
      exit 1
    fi

    case "${ID:-}" in
      arch | manjaro)
        "${ROOT_DIR}/bootstrap/arch.sh"
        ;;
      ubuntu | debian)
        "${ROOT_DIR}/bootstrap/${ID}.sh"
        ;;
      *)
        echo "unsupported linux distribution: ${ID:-unknown}" >&2
        exit 1
        ;;
    esac
    ;;
  *)
    echo "unsupported os: $(uname -s)" >&2
    exit 1
    ;;
esac

export PATH="${HOME}/.local/bin:${HOME}/.cargo/bin:/opt/homebrew/bin:/usr/local/bin:${PATH}"
"${ROOT_DIR}/scripts/preflight"
chezmoi init --source "${ROOT_DIR}"
"${ROOT_DIR}/scripts/chezmoi" apply
