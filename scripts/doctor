#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
# shellcheck source=scripts/lib/env
source "${ROOT_DIR}/scripts/lib/env"
# shellcheck source=scripts/lib/plan
source "${ROOT_DIR}/scripts/lib/plan"
# shellcheck source=scripts/lib/platform
source "${ROOT_DIR}/scripts/lib/platform"
dotfiles_load_private_env

missing=0

check_command() {
  local name=$1
  if command -v "${name}" >/dev/null 2>&1; then
    printf "ok   %s\n" "${name}"
  else
    printf "miss %s\n" "${name}"
    missing=1
  fi
}

check_command git
check_command chezmoi
check_command mise
check_command zsh
check_command vim

if "${ROOT_DIR}/scripts/preflight" >/dev/null; then
  printf "ok   private env\n"
  if dotfiles_host_file >/dev/null && dotfiles_package_sets >/dev/null && dotfiles_devtools >/dev/null; then
    printf "ok   host plan\n"
  else
    printf "miss host plan\n"
    missing=1
  fi
else
  printf "miss private env\n"
  missing=1
fi

case "$(dotfiles_kernel_name)" in
  Darwin)
    check_command brew
    ;;
  Linux)
    case "$(dotfiles_linux_release_id)" in
      arch | manjaro)
        check_command pacman
        ;;
      ubuntu | debian)
        check_command apt
        ;;
      *)
        printf "warn unsupported linux distribution: %s\n" "$(dotfiles_linux_release_id)"
        ;;
    esac
    ;;
esac

exit "${missing}"
