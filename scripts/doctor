#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
# shellcheck source=scripts/lib/env.sh
source "${ROOT_DIR}/scripts/lib/env.sh"
# shellcheck source=scripts/lib/plan.sh
source "${ROOT_DIR}/scripts/lib/plan.sh"
# shellcheck source=scripts/lib/platform.sh
source "${ROOT_DIR}/scripts/lib/platform.sh"

missing=0

print_command_status() {
  local name=$1

  if command -v "${name}" >/dev/null 2>&1; then
    printf "ok   %s\n" "${name}"
    return 0
  fi

  printf "miss %s\n" "${name}"
  return 1
}

print_check_details() {
  local output=$1
  local line

  while IFS= read -r line; do
    [[ -n "${line}" ]] || continue
    printf "  %s\n" "${line}"
  done <<<"${output}"
}

run_check() {
  local name=$1
  shift
  local output

  if output="$("$@" 2>&1)"; then
    printf "ok   %s\n" "${name}"
    return 0
  fi

  printf "miss %s\n" "${name}"
  if [[ -n "${output}" ]]; then
    print_check_details "${output}"
  fi
  return 1
}

# shellcheck disable=SC2329
validate_host_plan() {
  dotfiles_load_private_env
  dotfiles_host_file >/dev/null
  dotfiles_package_sets >/dev/null
  dotfiles_devtools >/dev/null
}

check_core_commands() {
  local failed=0

  print_command_status git || failed=1
  print_command_status chezmoi || failed=1
  print_command_status mise || failed=1
  print_command_status zsh || failed=1
  print_command_status vim || failed=1

  case "$(dotfiles_kernel_name)" in
    Darwin)
      print_command_status brew || failed=1
      ;;
    Linux)
      case "$(dotfiles_linux_release_id)" in
        arch | manjaro)
          print_command_status pacman || failed=1
          ;;
        debian)
          print_command_status apt || failed=1
          ;;
        *)
          printf "warn unsupported linux distribution: %s\n" "$(dotfiles_linux_release_id)"
          ;;
      esac
      ;;
  esac

  return "${failed}"
}

printf "checks:\n"
if ! check_core_commands; then
  missing=1
fi

if run_check "private env" "${ROOT_DIR}/scripts/preflight"; then
  if ! run_check "host plan" validate_host_plan; then
    missing=1
  fi
else
  missing=1
  printf "miss host plan\n"
  printf "  skipped: private env check failed\n"
  missing=1
fi

exit "${missing}"
