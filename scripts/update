#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"

# shellcheck source=scripts/lib/env
source "${ROOT_DIR}/scripts/lib/env"
# shellcheck source=scripts/lib/common
source "${ROOT_DIR}/scripts/lib/common"
dotfiles_load_private_env

update_os_packages() {
  case "$(uname -s)" in
    Darwin)
      run_step "brew update" brew update
      run_step "install package sets" "${ROOT_DIR}/scripts/packages"
      run_step "brew cleanup" brew cleanup
      ;;
    Linux)
      if command -v pacman >/dev/null 2>&1; then
        run_step "pacman system upgrade" sudo pacman -Syu --noconfirm
      elif command -v apt >/dev/null 2>&1; then
        run_step "apt update" sudo apt update
        run_step "apt upgrade" sudo apt upgrade -y
      fi
      run_step "install package sets" "${ROOT_DIR}/scripts/packages"
      ;;
    *)
      echo "unsupported os: $(uname -s)" >&2
      exit 1
      ;;
  esac
}

"${ROOT_DIR}/scripts/preflight" >/dev/null

update_os_packages
run_step_allow_fail "mise upgrade" mise upgrade
run_step "mise install" mise install
run_step "apply dotfiles" "${ROOT_DIR}/scripts/chezmoi" apply
run_step "doctor" "${ROOT_DIR}/scripts/doctor"
