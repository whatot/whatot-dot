#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"

# shellcheck source=scripts/lib/env.sh
source "${ROOT_DIR}/scripts/lib/env.sh"
# shellcheck source=scripts/lib/platform.sh
source "${ROOT_DIR}/scripts/lib/platform.sh"
# shellcheck source=scripts/lib/common.sh
source "${ROOT_DIR}/scripts/lib/common.sh"
dotfiles_load_private_env
init_sudo_cmd

usage() {
  cat <<'EOF'
usage: scripts/update [command]

commands:
  all                run doctor, then update packages, mise tools, and dotfiles (default)
  packages           update operating system packages and install declared package sets
  mise               update mise and install declared tool versions
  dotfiles           apply chezmoi-managed dotfiles
EOF
}

update_os_packages() {
  local kernel_name
  local linux_id

  kernel_name="$(dotfiles_kernel_name)"

  case "${kernel_name}" in
    Darwin)
      run_step "brew update" brew update
      run_step "brew upgrade" brew upgrade
      run_step "install package sets" "${ROOT_DIR}/scripts/packages"
      run_step "brew cleanup" brew cleanup
      ;;
    Linux)
      linux_id="$(dotfiles_linux_release_id)"
      case "${linux_id}" in
        arch | manjaro)
          run_step "pacman system upgrade" "${sudo_cmd[@]}" pacman -Syu --noconfirm
          ;;
        debian)
          run_apt_update_once
          run_step "apt upgrade" "${sudo_cmd[@]}" apt upgrade -y
          ;;
        *)
          echo "unsupported linux distribution: ${linux_id}" >&2
          exit 1
          ;;
      esac
      run_step "install package sets" "${ROOT_DIR}/scripts/packages"
      ;;
    *)
      echo "unsupported os: ${kernel_name}" >&2
      exit 1
      ;;
  esac
}

update_mise_tools() {
  run_step_allow_fail "mise upgrade" mise upgrade
  run_step "mise install" mise install
}

apply_dotfiles() {
  run_step "apply dotfiles" "${ROOT_DIR}/scripts/chezmoi" apply
}

run_doctor() {
  run_step "doctor" "${ROOT_DIR}/scripts/doctor"
}

run_all() {
  run_doctor
  update_os_packages
  update_mise_tools
  apply_dotfiles
}

case "${1:-all}" in
  all)
    run_all
    ;;
  packages)
    run_doctor
    update_os_packages
    ;;
  mise)
    run_doctor
    update_mise_tools
    ;;
  dotfiles)
    run_doctor
    apply_dotfiles
    ;;
  -h | --help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
