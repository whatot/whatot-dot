#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"

# shellcheck source=scripts/lib/env
source "${ROOT_DIR}/scripts/lib/env"
# shellcheck source=scripts/lib/platform
source "${ROOT_DIR}/scripts/lib/platform"
# shellcheck source=scripts/lib/common
source "${ROOT_DIR}/scripts/lib/common"
dotfiles_load_private_env
init_sudo_cmd

usage() {
  cat <<'EOF'
usage: scripts/update [command]

commands:
  all                update packages, mise tools, dotfiles, and environment checks (default)
  packages           update operating system packages and install declared package sets
  mise               update mise and install declared tool versions
  dotfiles           apply chezmoi-managed dotfiles
  devtools           install host-enabled development tools
EOF
}

update_os_packages() {
  local kernel_name
  local linux_id

  kernel_name="$(dotfiles_kernel_name)"

  case "${kernel_name}" in
    Darwin)
      run_step "brew update" brew update
      run_step "install package sets" "${ROOT_DIR}/scripts/packages"
      run_step "brew cleanup" brew cleanup
      ;;
    Linux)
      linux_id="$(dotfiles_linux_release_id)"
      case "${linux_id}" in
        arch | manjaro)
          run_step "pacman system upgrade" "${sudo_cmd[@]}" pacman -Syu --noconfirm
          ;;
        ubuntu | debian)
          run_apt_update_once
          run_step "apt upgrade" "${sudo_cmd[@]}" apt upgrade -y
          ;;
        *)
          echo "unsupported linux distribution: ${linux_id}" >&2
          exit 1
          ;;
      esac
      run_step "install package sets" "${ROOT_DIR}/scripts/packages"
      ;;
    *)
      echo "unsupported os: ${kernel_name}" >&2
      exit 1
      ;;
  esac
}

update_mise_tools() {
  run_step_allow_fail "mise upgrade" mise upgrade
  run_step "mise install" mise install
}

apply_dotfiles() {
  run_step "apply dotfiles" "${ROOT_DIR}/scripts/chezmoi" apply
}

install_host_devtools() {
  run_step "install host devtools" "${ROOT_DIR}/scripts/devtools" host
}

show_env_status() {
  run_step "show env" "${ROOT_DIR}/scripts/show-env"
}

run_all() {
  update_os_packages
  update_mise_tools
  apply_dotfiles
  show_env_status
}

"${ROOT_DIR}/scripts/preflight" >/dev/null

case "${1:-all}" in
  all)
    run_all
    ;;
  packages)
    update_os_packages
    ;;
  mise)
    update_mise_tools
    ;;
  dotfiles)
    apply_dotfiles
    ;;
  devtools)
    install_host_devtools
    ;;
  -h | --help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
