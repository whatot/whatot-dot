#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
# shellcheck source=scripts/lib/env
source "${ROOT_DIR}/scripts/lib/env"
# shellcheck source=scripts/lib/plan
source "${ROOT_DIR}/scripts/lib/plan"
# shellcheck source=scripts/lib/common
source "${ROOT_DIR}/scripts/lib/common"
dotfiles_load_private_env

collect_shell_files() {
  local dir

  for dir in scripts bootstrap; do
    if [[ -d "${ROOT_DIR}/${dir}" ]]; then
      find "${ROOT_DIR}/${dir}" -type f
    fi
  done
}

run_tool() {
  local tool=$1
  shift

  if command -v mise >/dev/null 2>&1; then
    mise exec -- "${tool}" "$@"
  elif command -v "${tool}" >/dev/null 2>&1; then
    "${tool}" "$@"
  else
    echo "${tool} is required. Run mise install first." >&2
    return 1
  fi
}

run_dprint_check() {
  run_tool dprint check --incremental=false --excludes ".cache"
}

render_template() {
  local source_path=$1
  local output_path=$2
  local host_data_file=$3

  run_tool chezmoi execute-template \
    --source "${ROOT_DIR}" \
    --override-data-file "${host_data_file}" \
    --file "${source_path}" >"${output_path}"
}

write_vim_plug_stub() {
  local output_path=$1

  cat >"${output_path}" <<'EOF'
function! plug#begin(...) abort
  command! -nargs=* Plug call s:plug(<q-args>)
endfunction

function! s:plug(...) abort
endfunction

function! plug#end() abort
endfunction
EOF
}

validate_rendered_dotfiles() {
  local host_data_file
  local tmp_dir
  local tmp_home
  local rendered_zshenv
  local rendered_zshrc
  local rendered_network
  local rendered_tools
  local rendered_aliases
  local rendered_prompt
  local rendered_vimrc

  run_step "preflight rendered dotfiles" "${ROOT_DIR}/scripts/preflight"
  host_data_file="$(dotfiles_host_file)"

  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "${tmp_dir:-}"' RETURN
  tmp_home="${tmp_dir}/home"
  mkdir -p "${tmp_home}/.vim/autoload" "${tmp_home}/.zsh"

  rendered_zshenv="${tmp_dir}/.zshenv"
  rendered_zshrc="${tmp_dir}/.zshrc"
  rendered_network="${tmp_home}/.zsh/network.zsh"
  rendered_tools="${tmp_home}/.zsh/tools.zsh"
  rendered_aliases="${tmp_home}/.zsh/aliases.zsh"
  rendered_prompt="${tmp_home}/.zsh/prompt.zsh"
  rendered_vimrc="${tmp_home}/.vimrc"

  render_template "${ROOT_DIR}/home/dot_zshenv.tmpl" "${rendered_zshenv}" "${host_data_file}"
  render_template "${ROOT_DIR}/home/dot_zshrc.tmpl" "${rendered_zshrc}" "${host_data_file}"
  render_template "${ROOT_DIR}/home/dot_zsh/network.zsh.tmpl" "${rendered_network}" "${host_data_file}"
  render_template "${ROOT_DIR}/home/dot_zsh/tools.zsh.tmpl" "${rendered_tools}" "${host_data_file}"
  render_template "${ROOT_DIR}/home/dot_zsh/aliases.zsh.tmpl" "${rendered_aliases}" "${host_data_file}"
  render_template "${ROOT_DIR}/home/dot_zsh/prompt.zsh.tmpl" "${rendered_prompt}" "${host_data_file}"
  render_template "${ROOT_DIR}/home/dot_vimrc.tmpl" "${rendered_vimrc}" "${host_data_file}"

  cp "${ROOT_DIR}/home/dot_vim/"*.vim "${tmp_home}/.vim/"
  write_vim_plug_stub "${tmp_home}/.vim/autoload/plug.vim"

  run_step "zsh -n rendered zshenv" run_tool zsh -n "${rendered_zshenv}"
  run_step "zsh -n rendered zshrc" run_tool zsh -n "${rendered_zshrc}"
  run_step "zsh -n rendered network" run_tool zsh -n "${rendered_network}"
  run_step "zsh -n rendered tools" run_tool zsh -n "${rendered_tools}"
  run_step "zsh -n rendered aliases" run_tool zsh -n "${rendered_aliases}"
  run_step "zsh -n rendered prompt" run_tool zsh -n "${rendered_prompt}"
  run_step "zsh source rendered zshrc" env HOME="${tmp_home}" PATH="/usr/bin:/bin:/usr/sbin:/sbin" zsh -fc \
    "source ${rendered_zshrc}; alias m >/dev/null; whence -w setup_prompt >/dev/null; whence -w setproxy >/dev/null"
  run_step "vim load rendered vimrc" env HOME="${tmp_home}" vim -Nu NONE -n -es \
    -c "set nomore" \
    -c "source ${rendered_vimrc}" \
    -c "quitall"
}

main() {
  local shell_files=()
  local shell_file

  while IFS= read -r shell_file; do
    shell_files+=("${shell_file}")
  done < <(collect_shell_files | sort -u)

  if [[ ${#shell_files[@]} -gt 0 ]]; then
    run_step "shellcheck scripts" run_tool shellcheck -x "${shell_files[@]}"
    run_step "shfmt check scripts" run_tool shfmt -d -i 2 -ci "${shell_files[@]}"
  fi

  if [[ -f "${ROOT_DIR}/home/dot_zshenv.tmpl" ]]; then
    run_step "shfmt check zshenv" run_tool shfmt -d -i 2 -ci "${ROOT_DIR}/home/dot_zshenv.tmpl"
  fi

  validate_rendered_dotfiles
  run_step "dprint check" run_dprint_check
}

main "$@"
